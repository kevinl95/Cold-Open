{
  "name": "coldopen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:pages": "npm run build && node scripts/build-pages.mjs",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "start": "npm run build:pages && node dist/aggregator/src/server.js",
    "seed:novice": "npm run build && node dist/scripts/seed.js novice-file-management",
    "seed:competent": "npm run build && node dist/scripts/seed.js competent-file-management"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "zod": "^3.0.0"
  }
}
